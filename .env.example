# Copie ce fichier en `.env` et renseigne tes valeurs.
# (Préfixe EXPO_PUBLIC_ = embarqué dans l'app ; ces clés sont publiques par design.)
# Sans Supabase, l'app tourne en mode démo local (sans connexion ni sync).

EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Google : "Web client ID" (et NON le client iOS) — sert d'audience au token.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# RevenueCat (monétisation). Clé API publique par plateforme. Vide = Premium désactivé.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxx
